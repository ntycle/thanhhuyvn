rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: kiểm tra user hiện tại có phải admin không
    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;
      
      // User đăng ký tạo mới (BƯỚC 1: Bắt buộc role phải là 'user')
      allow create: if request.auth.uid == uid 
                    && request.resource.data.role == 'user';
      
      // Admin được xoá
      allow delete: if isAdmin();
      
      // LUẬT CẬP NHẬT (Trọng tâm)
      allow update: if isAdmin() || (
        request.auth.uid == uid 
        // BƯỚC 1: Tuyệt đối CẤM đổi quyền (thay đổi trường role)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        && (
          // Đổi thông tin linh tinh thì cho qua
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['bankAccount', 'bankName', 'bankFullName'])
          // NHƯNG nếu đụng vào Ngân Hàng, thì bắt buộc bankAccount trên database cũ hiện tại phải ĐANG RỖNG mới cho lưu!
          || resource.data.get('bankAccount', '') == ''
        )
      );
    }


    // ── Orders collection
    match /orders/{orderId} {
      // Cho phép User đọc đơn hàng của họ HOẶC đơn hàng chưa ai gán (để có thể tìm và gán)
      allow read: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userId == null));
      allow write: if isAdmin();
      allow create: if request.auth != null
                    && !isAdmin()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && !isAdmin()
                    && resource.data.userId == request.auth.uid
                    && resource.data['Tên Item'] == 'Không có thông tin';

      // CODE MỚI THAY THẾ Ở CÚ NHÁY NÀY:
      allow update: if request.auth != null
                    && !isAdmin()
                    && (
                      (
                        resource.data.userId == null
                        && request.resource.data.userId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['thanhToan'])
                      )
                      ||
                      (
                        resource.data.userId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['thanhToan', 'updatedAt'])
                        && request.resource.data.thanhToan == 'Đang chờ xử lý'
                      )
                    );
    }

    // ── Cấp quyền cho link rút gọn
    match /shortlinks/{linkId} {
      // Bắt buộc public để Guest có thể truy cập link rút gọn
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']) 
                    || isAdmin();
      allow create, delete: if isAdmin();
    }
    
    // ── Cấp quyền cho collection payment_requests
    match /payment_requests/{docId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

  }
}
